{
    "name": "uv-vscode",
    "displayName": "Practical UV",
    "description": "Practical plugin for handling pyproject.toml generated by uv",
    "publisher": "wizhut",
    "repository": {
        "type": "git",
        "url": "https://github.com/wizhut/uv-vscode"
    },
    "version": "0.1.5",
    "license": "MIT",
    "icon": "icon.png",
    "author": {
        "name": "Vassilios Karakoidas",
        "email": "vassilios.karakoidas@wizhut.tech"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onLanguage:toml"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "toml",
                "extensions": [
                    ".toml"
                ],
                "aliases": [
                    "TOML",
                    "toml"
                ]
            }
        ],
        "grammars": [
            {
                "language": "toml",
                "scopeName": "source.toml",
                "path": "./syntaxes/toml.tmLanguage.json"
            }
        ],
        "commands": [
            {
                "command": "uv.sync",
                "title": "UV: Sync"
            },
            {
                "command": "uv.add",
                "title": "UV: Add"
            },
            {
                "command": "uv.run",
                "title": "UV: Run"
            },
            {
                "command": "uv.upgradeVersion",
                "title": "UV: Upgrade Version"
            },
            {
                "command": "uv.selectVersion",
                "title": "UV: Select Version to Upgrade To"
            },
            {
                "command": "uv.selectPythonVersion",
                "title": "UV: Select Python Version"
            },
            {
                "command": "uv.showDependencies",
                "title": "UV: Show Dependencies"
            }
        ]
    },
    "scripts": {
        "package": "vsce package",
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "devDependencies": {
        "@types/node": "18.x",
        "@types/vscode": "~1.85.0",
        "@vscode/vsce": "^3.9.1",
        "typescript": "^5.3.3"
    }
}
